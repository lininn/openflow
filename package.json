{
  "name": "@lininn/openflow",
  "version": "0.4.0-beta.1",
  "description": "OpenSpec + Superpowers workflow orchestrator for Claude Code",
  "bin": {
    "openflow": "bin/openflow.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check": "npm run lint && npm run build && npm test",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "postinstall": "node ./scripts/postinstall.js"
  },
  "keywords": [
    "claude-code",
    "openspec",
    "superpowers",
    "workflow",
    "skill"
  ],
  "author": "lininn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lininn/openflow.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "dist",
    "openflow-architecture.png",
    "openflow-architecture.svg",
    "openflow-workflow.png",
    "openflow-workflow.svg",
    "templates",
    "scripts"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^13.4.3",
    "ora": "^8.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
